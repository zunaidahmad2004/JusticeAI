# ─── Copy this as your Render Environment Variables ──────────────────────────
# Set each key in Render Dashboard → Environment → Add Environment Variable

PORT=10000
NODE_ENV=production

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/justice_ai?retryWrites=true&w=majority

# JWT Secrets — generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Google Gemini API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_key_here

# Your Render frontend URL (set AFTER frontend is deployed)
CLIENT_URL=https://justiceai-frontend.onrender.com

# File uploads (ephemeral on Render free tier)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Optional: SMTP for 2FA OTP emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
